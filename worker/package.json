{
  "name": "club-api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "db:migrate:prod": "wrangler d1 migrations apply club-prod",
    "db:migrate:staging": "wrangler d1 migrations apply club-staging --env staging",
    "migrate-data": "tsx scripts/migrate-data.ts",
    "migrate-data:staging": "tsx scripts/migrate-data.ts --env staging"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
